{
  "name": "thungkhru61",
  "version": "0.1.0",
  "private": true,
  "description": "ThungKhru61 — Market PWA for ตลาดทุ่งครุ 61 with flash sales, interactive map, proximity alerts, and crowd forecasting.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.local -e .env -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e .env.local -e .env -- prisma migrate dev",
    "db:seed": "dotenv -e .env.local -e .env -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e .env.local -e .env -- prisma studio",
    "db:reset": "dotenv -e .env.local -e .env -- prisma migrate reset --force",
    "bootstrap": "pnpm install && pnpm db:generate",
    "postinstall": "prisma generate || true"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "clsx": "^2.1.1",
    "mapbox-gl": "^3.22.0",
    "next": "15.5.15",
    "prisma": "^6.19.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^2.5.5",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/mapbox-gl": "^3.5.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.5.15",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.17"
  }
}
